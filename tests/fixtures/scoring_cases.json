  "text_similarity": {
    "description": "_text_similarity: SequenceMatcher ratio on first 300 chars lowered",
    "cases": [
      {
        "id": "identical",
        "a": "The company is investing heavily in AI-driven automation across its supply chain.",
        "b": "The company is investing heavily in AI-driven automation across its supply chain.",
        "expected": 1.0
      },
      {
        "id": "nearly_identical",
        "a": "The company is investing heavily in AI-driven automation across its supply chain.",
        "b": "The company is investing heavily in AI driven automation across its supply chain.",
        "expected_min": 0.95
      },
      {
        "id": "similar_topic",
        "a": "Microsoft announced a $10 billion investment in AI infrastructure for cloud services.",
        "b": "Microsoft revealed a $10B AI infrastructure investment for its cloud computing division.",
        "expected_min": 0.5
      },
      {
        "id": "completely_different",
        "a": "The company reported quarterly earnings of $5.2 billion in the fiscal fourth quarter.",
        "b": "New regulations require companies to disclose climate change risks in their annual filings.",
        "expected_max": 0.4
      },
      {
        "id": "empty_strings",
        "a": "",
        "b": "",
        "expected": 1.0
      },
      {
        "id": "case_insensitive",
        "a": "AI INVESTMENT IN CLOUD COMPUTING",
        "b": "ai investment in cloud computing",
        "expected": 1.0,
        "note": "lowered before comparison"
      }
    ]
  },
  "evidence_grouping": {
    "description": "_group_passages: greedy clustering by text similarity",
    "cases": [
      {
        "id": "two_similar_one_different",
        "passages": [
          "The company invested $500M in AI infrastructure to modernize its data centers and computing platforms.",
          "The company invested $500M in AI infrastructure to modernize data centers and cloud computing.",
          "Revenue grew 15% year-over-year driven by strong consumer demand in the holiday season."
        ],
        "expected_group_count": 2,
        "expected_first_group_size": 2
      },
      {
        "id": "all_different",
        "passages": [
          "Apple launched a new AI-powered chip for its latest iPhone series.",
          "The Federal Reserve raised interest rates by 25 basis points.",
          "Tesla reported record deliveries in Q4 with over 500,000 vehicles."
        ],
        "expected_group_count": 3
      },
      {
        "id": "single_passage",
        "passages": [
          "The company is exploring generative AI applications for customer service."
