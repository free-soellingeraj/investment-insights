  "subsidiary_attribution": {
    "description": "compute_subsidiary_attribution: parent + weighted subsidiary scores, capped boost",
    "cases": [
      {
        "id": "single_subsidiary",
        "parent_opportunity": 0.6,
        "parent_realization": 0.4,
        "subsidiaries": [
          {"company_name": "SubCo", "ownership_pct": 0.8, "opportunity": 0.5, "realization": 0.3}
        ],
        "expected_opp_boost": 0.2,
        "expected_real_boost": 0.2,
        "note": "0.8*0.5=0.4 capped to 0.2; 0.8*0.3=0.24 capped to 0.2"
      },
      {
        "id": "no_subsidiaries",
        "parent_opportunity": 0.6,
        "parent_realization": 0.4,
        "subsidiaries": [],
        "expected_adjusted_opp": 0.6,
        "expected_adjusted_real": 0.4
      },
      {
        "id": "result_capped_at_1",
        "parent_opportunity": 0.95,
        "parent_realization": 0.95,
        "subsidiaries": [
          {"company_name": "SubCo", "ownership_pct": 1.0, "opportunity": 0.5, "realization": 0.5}
        ],
        "expected_adjusted_opp": 1.0,
        "expected_adjusted_real": 1.0,
        "note": "0.95 + 0.2 capped to 1.0"
      }
    ]
  }
