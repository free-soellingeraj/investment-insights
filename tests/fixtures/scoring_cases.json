{
  "recency_decay": {
    "description": "compute_recency: 0.7^years_old, floor 0.3",
    "cases": [
      {
        "id": "today",
        "evidence_date": "2026-03-08",
        "reference_date": "2026-03-08",
        "expected": 1.0
      },
      {
        "id": "1_year_old",
        "evidence_date": "2025-03-08",
        "reference_date": "2026-03-08",
        "expected_approx": 0.7,
        "tolerance": 0.01
      },
      {
        "id": "2_years_old",
        "evidence_date": "2024-03-08",
        "reference_date": "2026-03-08",
        "expected_approx": 0.49,
        "tolerance": 0.01
      },
      {
        "id": "5_years_old",
        "evidence_date": "2021-03-08",
        "reference_date": "2026-03-08",
        "expected_approx": 0.3,
        "tolerance": 0.01,
        "note": "floors at 0.3"
      },
      {
        "id": "none_date",
        "evidence_date": null,
        "reference_date": "2026-03-08",
        "expected": 0.3,
        "note": "None date returns floor"
      },
      {
        "id": "future_date",
        "evidence_date": "2027-01-01",
        "reference_date": "2026-03-08",
        "expected": 1.0,
        "note": "future dates clamp years_old to 0"
      }
    ]
  },
  "magnitude_saturation": {
    "description": "compute_magnitude: dollar_mid / company_revenue, capped at 1.0",
    "cases": [
      {
        "id": "small_amount",
        "dollar_mid": 1000000,
        "company_revenue": 10000000000,
        "expected": 0.0001
      },
      {
        "id": "medium_amount",
        "dollar_mid": 500000000,
        "company_revenue": 10000000000,
        "expected": 0.05
      },
      {
        "id": "large_amount_exceeds_revenue",
        "dollar_mid": 20000000000,
        "company_revenue": 10000000000,
        "expected": 1.0,
        "note": "capped at 1.0"
      },
      {
        "id": "equal_to_revenue",
        "dollar_mid": 5000000,
        "company_revenue": 5000000,
        "expected": 1.0
      },
      {
        "id": "zero_dollar",
        "dollar_mid": 0,
        "company_revenue": 10000000000,
        "expected": 0.0,
        "note": "falsy dollar_mid returns 0"
      },
      {
        "id": "none_dollar",
        "dollar_mid": null,
        "company_revenue": 10000000000,
        "expected": 0.0
      },
      {
        "id": "zero_revenue",
        "dollar_mid": 1000000,
        "company_revenue": 0,
        "expected": 0.0,
        "note": "zero revenue returns 0"
      },
      {
        "id": "none_revenue",
        "dollar_mid": 1000000,
        "company_revenue": null,
        "expected": 0.0
      },
      {
        "id": "negative_dollar",
        "dollar_mid": -500000,
        "company_revenue": 10000000,
        "expected": 0.05,
        "note": "abs(dollar_mid) is used"
      }
    ]
  },
  "factor_score": {
    "description": "compute_factor_score: specificity * magnitude * stage_weight * recency",
    "cases": [
      {
        "id": "all_ones",
        "specificity": 1.0,
        "magnitude": 1.0,
        "stage_weight": 1.0,
        "recency": 1.0,
        "expected": 1.0
      },
      {
        "id": "all_zeros",
        "specificity": 0.0,
        "magnitude": 0.0,
        "stage_weight": 0.0,
        "recency": 0.0,
        "expected": 0.0
      },
      {
        "id": "typical_plan",
        "specificity": 0.6,
        "magnitude": 0.05,
        "stage_weight": 0.3,
        "recency": 0.7,
        "expected": 0.0063
      },
      {
        "id": "typical_investment",
        "specificity": 0.8,
        "magnitude": 0.1,
        "stage_weight": 0.7,
        "recency": 0.9,
        "expected": 0.0504
      },
      {
        "id": "typical_capture",
        "specificity": 0.9,
        "magnitude": 0.2,
        "stage_weight": 1.0,
        "recency": 1.0,
        "expected": 0.18
      },
      {
        "id": "one_zero_factor",
        "specificity": 0.9,
        "magnitude": 0.0,
        "stage_weight": 1.0,
        "recency": 1.0,
        "expected": 0.0,
        "note": "any zero factor zeroes the result"
      }
    ]
  },
  "dimension_aggregation": {
    "description": "1 - exp(-sum_of_factor_scores), capped at 1.0",
    "cases": [
      {
        "id": "zero_sum",
        "raw_sum": 0.0,
        "expected": 0.0
      },
      {
        "id": "small_sum",
        "raw_sum": 0.1,
        "expected_approx": 0.0952,
        "tolerance": 0.001
      },
      {
        "id": "medium_sum",
        "raw_sum": 0.5,
        "expected_approx": 0.3935,
        "tolerance": 0.001
      },
      {
        "id": "large_sum",
        "raw_sum": 1.0,
        "expected_approx": 0.6321,
        "tolerance": 0.001
      },
      {
        "id": "very_large_sum",
        "raw_sum": 5.0,
        "expected_approx": 0.9933,
        "tolerance": 0.001
      },
      {
        "id": "huge_sum",
        "raw_sum": 20.0,
        "expected_approx": 1.0,
        "tolerance": 0.0001,
        "note": "effectively capped at 1.0"
      }
    ]
  },
  "roi_calculation": {
    "description": "ROI = min(ROI_CAP, capture / max(opportunity, ROI_MIN_DENOMINATOR))",
    "cases": [
      {
        "id": "normal_case",
        "cost_opportunity": 0.5,
        "revenue_opportunity": 0.5,
        "cost_capture": 0.25,
        "revenue_capture": 0.25,
        "general_investment": 0.1,
        "expected_cost_roi": 0.5,
        "expected_revenue_roi": 0.5,
        "expected_combined_roi": 0.5
      },
      {
        "id": "zero_opportunity_uses_min_denom",
        "cost_opportunity": 0.0,
        "revenue_opportunity": 0.0,
        "cost_capture": 0.01,
        "revenue_capture": 0.01,
        "general_investment": 0.0,
        "expected_cost_roi": 1.0,
        "expected_revenue_roi": 1.0,
        "expected_combined_roi": 1.0
      },
      {
        "id": "capped_at_2",
        "cost_opportunity": 0.1,
        "revenue_opportunity": 0.1,
        "cost_capture": 0.9,
        "revenue_capture": 0.9,
        "general_investment": 0.0,
        "expected_cost_roi": 2.0,
        "expected_revenue_roi": 2.0,
        "expected_combined_roi": 2.0,
        "note": "9.0 would be uncapped; capped to ROI_CAP=2.0"
      },
      {
        "id": "asymmetric_roi",
        "cost_opportunity": 0.8,
        "revenue_opportunity": 0.2,
        "cost_capture": 0.4,
        "revenue_capture": 0.6,
        "general_investment": 0.0,
        "expected_cost_roi": 0.5,
        "expected_revenue_roi": 2.0,
        "expected_combined_roi": 1.25
      }
    ]
  },
  "ai_index_sigmoid": {
    "description": "AI Index: P(capture) * dollar_potential",
    "cases": [
      {
        "id": "all_plan",
        "plan_dollars": 1000000,
        "investment_dollars": 0,
        "capture_dollars": 0,
        "opportunity_usd": null,
        "note": "weighted = 0.10, low probability"
      },
      {
        "id": "all_investment",
        "plan_dollars": 0,
        "investment_dollars": 1000000,
        "capture_dollars": 0,
        "opportunity_usd": null,
        "note": "weighted = 0.35 = midpoint, moderate probability"
      },
      {
        "id": "all_capture",
        "plan_dollars": 0,
        "investment_dollars": 0,
        "capture_dollars": 1000000,
        "opportunity_usd": null,
        "note": "weighted = 0.70, high probability"
      },
      {
        "id": "mixed_evidence",
        "plan_dollars": 300000,
        "investment_dollars": 500000,
        "capture_dollars": 200000,
        "opportunity_usd": null,
        "note": "weighted = (0.10*300k + 0.35*500k + 0.70*200k) / 1M = 0.345"
      },
      {
        "id": "zero_evidence",
        "plan_dollars": 0,
        "investment_dollars": 0,
        "capture_dollars": 0,
        "opportunity_usd": null,
        "expected_probability": 0.05,
        "expected_ai_index_usd": 0.0
      },
      {
        "id": "with_opportunity_usd",
        "plan_dollars": 500000,
        "investment_dollars": 500000,
        "capture_dollars": 0,
        "opportunity_usd": 5000000,
        "note": "dollar_base should be opportunity_usd, not evidence_total"
      },
      {
        "id": "zero_evidence_with_opportunity",
        "plan_dollars": 0,
        "investment_dollars": 0,
        "capture_dollars": 0,
        "opportunity_usd": 5000000,
        "note": "zero evidence but nonzero opp_usd - special case"
      }
    ]
  },
  "quadrant_assignment": {
    "description": "Quadrant assignment based on opportunity/realization thresholds",
