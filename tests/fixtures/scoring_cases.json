        "realization": 0.3,
        "expected_quadrant": "high_opp_low_real",
        "expected_label": "Untapped Potential"
      },
      {
        "id": "low_opp_high_real",
        "opportunity": 0.3,
        "realization": 0.7,
        "expected_quadrant": "low_opp_high_real",
        "expected_label": "Over-investing?"
      },
      {
        "id": "low_opp_low_real",
        "opportunity": 0.3,
        "realization": 0.3,
        "expected_quadrant": "low_opp_low_real",
        "expected_label": "Emerging"
      },
      {
        "id": "exact_boundary_high",
        "opportunity": 0.5,
        "realization": 0.5,
        "expected_quadrant": "high_opp_high_real",
        "expected_label": "AI Leaders",
        "note": ">= threshold means high"
      },
      {
        "id": "boundary_opp_high_real_low",
