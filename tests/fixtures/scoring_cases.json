  "cost_capture_formula": {
    "description": "employees * avg_salary * ai_applicability * productivity_gain * evidence_fraction",
    "cases": [
      {
        "id": "tech_company",
        "employees": 10000,
        "sector": "Technology",
        "confidence": 0.8,
        "stage": "realized",
        "expected_salary": 100000,
        "note": "annual = 10000 * 100000 * 0.15 * 0.15 * (0.8*1.0)"
      },
      {
        "id": "small_company",
        "employees": 100,
        "sector": "Healthcare",
        "confidence": 0.5,
        "stage": "planned",
        "expected_salary": 70000,
        "note": "annual = 100 * 70000 * 0.15 * 0.15 * (0.5*0.3)"
      },
      {
        "id": "zero_employees",
        "employees": 0,
        "sector": "Technology",
        "confidence": 0.9,
        "stage": "invested",
        "expected_annual": 0.0
      }
    ]
  },
